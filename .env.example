APP_ENV=development
APP_SECRET_KEY=replace-with-a-random-development-secret
DATABASE_URL=postgresql+asyncpg://douga:douga-local-only@127.0.0.1:5432/douga
TEST_DATABASE_URL=postgresql+asyncpg://douga:douga-local-only@127.0.0.1:5432/douga_test
REDIS_URL=redis://127.0.0.1:6379/0
JOB_DISPATCH_MODE=inline
S3_ENDPOINT_URL=http://127.0.0.1:4566
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=douga
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_ASSISTANT_MODEL=gpt-5.6
OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SECONDS=120
AIVIS_BASE_URL=http://127.0.0.1:10101
AIVIS_ENGINE_PATH=
AIVIS_AUTO_START=true
AIVIS_REQUEST_TIMEOUT_SECONDS=180
AIVIS_STARTUP_TIMEOUT_SECONDS=300
AIVIS_MAX_TEXT_LENGTH=500
ASSISTANT_PROVIDER=auto
ASSISTANT_HISTORY_LIMIT=30
ASSISTANT_RECENT_HISTORY_LIMIT=12
ASSISTANT_CONTEXT_COMPACT_TOKEN_THRESHOLD=120000
ASSISTANT_CACHED_INPUT_TOKEN_WEIGHT=0.1
ASSISTANT_MAX_TOOL_CALLS=1000
ASSISTANT_RUN_LIMIT_PER_HOUR=60
ASSISTANT_TOKEN_LIMIT_PER_RUN=600000
ASSISTANT_TOKEN_LIMIT_PER_HOUR=2000000
IMAGE_PROVIDER=fake
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
IMAGE_GENERATION_LIMIT_PER_HOUR=20
EXPORT_LIMIT_PER_HOUR=5
EXPORT_TIMEOUT_SECONDS=900
API_TOKEN_RATE_LIMIT_PER_MINUTE=120
MAX_JSON_REQUEST_BYTES=5242880
MAX_IMAGE_UPLOAD_BYTES=26214400
MAX_AUDIO_UPLOAD_BYTES=209715200
MAX_VIDEO_UPLOAD_BYTES=1073741824
MAX_IMAGE_PIXELS=80000000
MAX_AUDIO_DURATION_MS=14400000
MAX_VIDEO_DURATION_MS=3600000
MAX_CONCURRENT_UPLOADS=4
MAX_CONCURRENT_PREVIEWS=2
MAX_CONCURRENT_EXPORTS=1
ALLOWED_ORIGINS=["http://127.0.0.1:5173"]

# scripts/douga client only. Never commit a real token.
DOUGA_API_URL=http://127.0.0.1:8000/api/v1
DOUGA_WEB_URL=http://127.0.0.1:5173
DOUGA_API_TOKEN=
