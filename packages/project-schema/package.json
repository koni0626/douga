{
  "name": "@douga/project-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "json2ts -i schema/project-v1.schema.json -o src/generated/project-v1.d.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "8.20.0"
  },
  "devDependencies": {
    "json-schema-to-typescript": "15.0.4",
    "vitest": "4.1.10"
  }
}
