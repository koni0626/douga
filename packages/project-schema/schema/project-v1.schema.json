{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://douga.local/schemas/project-v1.schema.json",
  "title": "ProjectDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "name",
    "content_locale",
    "video",
    "caption_style",
    "scenes"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 100 },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "content_locale": { "type": "string", "enum": ["ja", "en"] },
    "video": { "$ref": "#/$defs/videoSettings" },
    "caption_style": { "$ref": "#/$defs/captionStyle" },
    "scenes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scene" },
      "maxItems": 1000
    },
    "audio_tracks": {
      "type": "array",
      "items": { "$ref": "#/$defs/audioTrack" },
      "maxItems": 1000,
      "default": []
    },
    "camera_effects": {
      "type": "array",
      "items": { "$ref": "#/$defs/cameraEffect" },
      "maxItems": 100,
      "default": []
    }
  },
  "$defs": {
    "cameraEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "preset",
        "start_ms",
        "end_ms",
        "intensity",
        "period_ms"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "preset": {
          "type": "string",
          "enum": [
            "handheld",
            "walk",
            "breathe",
            "float",
            "sway",
            "slow_rotate",
            "zoom_pulse",
            "heartbeat"
          ]
        },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 1 },
        "intensity": { "type": "number", "minimum": 0.1, "maximum": 3 },
        "period_ms": { "type": "integer", "minimum": 100, "maximum": 60000 }
      }
    },
    "videoSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "fps"],
      "properties": {
        "width": { "type": "integer", "minimum": 16, "maximum": 7680 },
        "height": { "type": "integer", "minimum": 16, "maximum": 4320 },
        "fps": { "type": "number", "exclusiveMinimum": 0, "maximum": 120 },
        "duration_ms": {
          "type": "integer",
          "minimum": 5000,
          "maximum": 3600000
        }
      }
    },
    "captionStyle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height",
        "padding",
        "font_family",
        "font_size",
        "line_height",
        "max_lines",
        "text_color",
        "background_color",
        "background_opacity",
        "border_radius",
        "text_align"
      ],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "padding": { "type": "number", "minimum": 0 },
        "font_family": { "type": "string", "minLength": 1 },
        "font_size": { "type": "number", "exclusiveMinimum": 0 },
        "font_weight": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900,
          "default": 600
        },
        "line_height": { "type": "number", "minimum": 0.5, "maximum": 3 },
        "max_lines": { "type": "integer", "minimum": 1, "maximum": 20 },
        "text_color": { "type": "string", "minLength": 1 },
        "background_color": { "type": "string", "minLength": 1 },
        "background_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "border_radius": { "type": "number", "minimum": 0 },
        "text_align": { "type": "string", "enum": ["left", "center", "right"] }
      }
    },
    "background": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "color"],
          "properties": {
            "type": { "const": "color" },
            "color": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "asset_id"],
          "properties": {
            "type": { "const": "asset" },
            "asset_id": { "type": "string", "minLength": 1 },
            "fallback_color": { "type": "string", "default": "#111827" }
          }
        }
      ]
    },
    "layerKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "time_ms",
        "easing",
        "x",
        "y",
        "width",
        "height",
        "rotation",
        "opacity",
        "flip_x",
        "flip_y"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "time_ms": { "type": "integer", "minimum": 0 },
        "easing": {
          "type": "string",
          "enum": [
            "linear",
            "ease_in",
            "ease_out",
            "ease_in_out",
            "bounce",
            "step"
          ]
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "rotation": { "type": "number" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "flip_x": { "type": "boolean" },
        "flip_y": { "type": "boolean" },
        "fill": { "type": "string", "minLength": 1 },
        "color": { "type": "string", "minLength": 1 },
        "font_size": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "baseLayer": {
      "type": "object",
      "required": ["id", "x", "y", "width", "height", "rotation", "opacity"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "track_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "maxLength": 200 },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 1 },
        "flip_x": { "type": "boolean", "default": false },
        "flip_y": { "type": "boolean", "default": false },
        "locked": { "type": "boolean", "default": false },
        "keyframes": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/layerKeyframe" }
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "rotation": { "type": "number" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "imageLayer": {
      "allOf": [
        { "$ref": "#/$defs/baseLayer" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "asset_id",
            "x",
            "y",
            "width",
            "height",
            "rotation",
            "opacity"
          ],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "track_id": { "type": "string", "minLength": 1 },
            "type": { "const": "image" },
            "name": { "type": "string", "maxLength": 200 },
            "asset_id": { "type": "string", "minLength": 1 },
            "start_ms": { "type": "integer", "minimum": 0 },
            "end_ms": { "type": "integer", "minimum": 1 },
            "flip_x": { "type": "boolean", "default": false },
            "flip_y": { "type": "boolean", "default": false },
            "locked": { "type": "boolean", "default": false },
            "keyframes": {
              "type": "array",
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/layerKeyframe" }
            },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "rotation": { "type": "number" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    },
    "textLayer": {
      "allOf": [
        { "$ref": "#/$defs/baseLayer" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "text",
            "font_size",
            "color",
            "x",
            "y",
            "width",
            "height",
            "rotation",
            "opacity"
          ],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "track_id": { "type": "string", "minLength": 1 },
            "type": { "const": "text" },
            "name": { "type": "string", "maxLength": 200 },
            "text": { "type": "string" },
            "writing_mode": {
              "type": "string",
              "enum": ["horizontal", "vertical"],
              "default": "horizontal"
            },
            "font_family": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "start_ms": { "type": "integer", "minimum": 0 },
            "end_ms": { "type": "integer", "minimum": 1 },
            "flip_x": { "type": "boolean", "default": false },
            "flip_y": { "type": "boolean", "default": false },
            "locked": { "type": "boolean", "default": false },
            "keyframes": {
              "type": "array",
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/layerKeyframe" }
            },
            "font_size": { "type": "number", "exclusiveMinimum": 0 },
            "color": { "type": "string", "minLength": 1 },
            "text_style": {
              "type": "string",
              "enum": ["solid", "neon"],
              "default": "solid"
            },
            "neon_color": { "type": "string", "minLength": 1 },
            "display_effect": {
              "type": "string",
              "enum": ["instant", "typewriter"],
              "default": "instant"
            },
            "characters_per_second": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 100
            },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "rotation": { "type": "number" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    },
    "shapeLayer": {
      "allOf": [
        { "$ref": "#/$defs/baseLayer" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "shape",
            "fill",
            "x",
            "y",
            "width",
            "height",
            "rotation",
            "opacity"
          ],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "track_id": { "type": "string", "minLength": 1 },
            "type": { "const": "shape" },
            "name": { "type": "string", "maxLength": 200 },
            "shape": { "type": "string", "enum": ["rectangle", "ellipse"] },
            "fill": { "type": "string", "minLength": 1 },
            "start_ms": { "type": "integer", "minimum": 0 },
            "end_ms": { "type": "integer", "minimum": 1 },
            "flip_x": { "type": "boolean", "default": false },
            "flip_y": { "type": "boolean", "default": false },
            "locked": { "type": "boolean", "default": false },
            "keyframes": {
              "type": "array",
              "maxItems": 1000,
              "items": { "$ref": "#/$defs/layerKeyframe" }
            },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "rotation": { "type": "number" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    },
    "layer": {
      "oneOf": [
        { "$ref": "#/$defs/imageLayer" },
        { "$ref": "#/$defs/textLayer" },
        { "$ref": "#/$defs/shapeLayer" }
      ]
    },
    "dialogue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "display_effect",
        "duration_mode",
        "manual_page_breaks"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "speaker": { "type": ["string", "null"], "maxLength": 100 },
        "start_ms": { "type": "integer", "minimum": 0 },
        "text": { "type": "string", "maxLength": 20000 },
        "display_effect": {
          "type": "string",
          "enum": ["instant", "fade", "typewriter"]
        },
        "duration_mode": {
          "type": "string",
          "enum": ["auto", "manual", "narration"]
        },
        "duration_ms": { "type": ["integer", "null"], "minimum": 1 },
        "manual_page_breaks": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "uniqueItems": true
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "background", "layers", "dialogues"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "background": { "$ref": "#/$defs/background" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/layer" },
          "maxItems": 1000
        },
        "dialogues": {
          "type": "array",
          "items": { "$ref": "#/$defs/dialogue" },
          "maxItems": 10000
        }
      }
    },
    "audioTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "asset_id",
        "role",
        "start_ms",
        "trim_start_ms",
        "volume",
        "loop",
        "fade_in_ms",
        "fade_out_ms",
        "ducking"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "asset_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "enum": ["narration", "bgm", "effect"] },
        "scene_id": { "type": ["string", "null"] },
        "dialogue_id": { "type": ["string", "null"] },
        "start_ms": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 1 },
        "trim_start_ms": { "type": "integer", "minimum": 0 },
        "volume": { "type": "number", "minimum": 0, "maximum": 2 },
        "loop": { "type": "boolean" },
        "fade_in_ms": { "type": "integer", "minimum": 0 },
        "fade_out_ms": { "type": "integer", "minimum": 0 },
        "ducking": { "type": "boolean" }
      }
    }
  }
}
